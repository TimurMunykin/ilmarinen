# App identity
APP_NAME={{APP_NAME}}
APP_SUBDOMAIN={{APP_SUBDOMAIN}}

# Database
DATABASE_URL=postgresql://{{APP_SUBDOMAIN}}:{{APP_SUBDOMAIN}}@postgres:5432/{{APP_SUBDOMAIN}}

# Auth (delegated to Ilmarinen platform)
ILMARINEN_URL=https://ilmarinen.muntim.ru
ILMARINEN_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Telegram notifications
TELEGRAM_BOT_TOKEN=

# Ports
API_PORT=3001
